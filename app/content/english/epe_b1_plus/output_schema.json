{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "epe_b1_plus_writing_eval_v1",
  "type": "object",
  "additionalProperties": false,
  "required": ["rubric_code", "criteria", "content_points", "strengths", "errors", "recommendations", "confidence"],
  "properties": {
    "rubric_code": {"type": "string"},
    "criteria": {
      "type": "array",
      "minItems": 4,
      "maxItems": 4,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["code", "score", "selected_band", "explanation", "evidence"],
        "properties": {
          "code": {
            "type": "string",
            "enum": ["task_achievement", "organisation_coherence", "range_vocabulary_grammar", "accuracy_vocabulary_grammar"]
          },
          "score": {"type": "integer", "minimum": 0, "maximum": 5},
          "selected_band": {"type": "integer", "minimum": 0, "maximum": 5},
          "explanation": {"type": "string"},
          "evidence": {"type": "array", "items": {"type": "string"}}
        }
      }
    },
    "content_points": {
      "type": "array",
      "minItems": 3,
      "maxItems": 3,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "status", "evidence", "comment"],
        "properties": {
          "id": {"type": "string"},
          "status": {"type": "string", "enum": ["missing", "mentioned", "partly_developed", "developed", "well_developed"]},
          "evidence": {"type": "string"},
          "comment": {"type": "string"}
        }
      }
    },
    "strengths": {"type": "array", "items": {"type": "string"}},
    "errors": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["category", "severity", "source_fragment", "corrected_fragment", "explanation"],
        "properties": {
          "category": {"type": "string"},
          "subcategory": {"type": "string"},
          "severity": {"type": "string", "enum": ["minor", "major", "critical"]},
          "source_fragment": {"type": "string"},
          "corrected_fragment": {"type": "string"},
          "explanation": {"type": "string"},
          "criterion_code": {"type": "string"}
        }
      }
    },
    "recommendations": {"type": "array", "items": {"type": "string"}},
    "confidence": {"type": "number", "minimum": 0, "maximum": 1}
  }
}
