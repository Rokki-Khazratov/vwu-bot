# --- App ---
APP_ENV=development
LOG_LEVEL=INFO

# --- Database ---
# Inside docker-compose the host is "postgres"; locally use "localhost".
DATABASE_URL=postgresql+asyncpg://vwu:vwu@postgres:5432/vwu

# --- Access (Phase 1: dev allowlist, no bot service token yet) ---
# Comma-separated Telegram user ids allowed to use the backend.
ALLOWLIST_TELEGRAM_IDS=111111111,222222222
# When true the backend requires the bot service token (Phase 6). Off in dev.
REQUIRE_SERVICE_TOKEN=false
BOT_SERVICE_TOKEN=
# Used in dev when a request omits the X-Telegram-User-Id header.
DEV_DEFAULT_TELEGRAM_ID=111111111

# --- Admin panel (/admin) ---
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me
SESSION_SECRET=change-me-too

# --- LLM (Gemini Pro) ---
GEMINI_API_KEY=
# Free AI Studio tier: use gemini-2.5-flash (or gemini-2.5-flash-lite).
# gemini-2.5-pro is NOT available on the free tier (requires billing).
GEMINI_MODEL=gemini-2.5-flash
GEMINI_BASE_URL=https://generativelanguage.googleapis.com
